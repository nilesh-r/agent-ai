# ==============================================================
#  AI CAREER AGENT - BACKEND ENVIRONMENT VARIABLES
# ==============================================================
# Copy this file to .env and fill in your values.

# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?appName=Cluster0
DATABASE_NAME=agent_db

# ── SECURITY ──────────────────────────────────────────────────
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CELERY / REDIS ────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── GEMINI ───────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── GOOGLE OAUTH ─────────────────────────────────────────────
# https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── GITHUB API ───────────────────────────────────────────────
# https://github.com/settings/tokens → Personal Access Token (classic)
GITHUB_TOKEN=ghp_...

# ── HR / CONTACT ENRICHMENT ──────────────────────────────────
# Hunter.io API (for recruiter email lookup)
# https://hunter.io/api
HUNTER_API_KEY=your-hunter-io-api-key

# ── ADZUNA JOB API ───────────────────────────────────────────
# https://developer.adzuna.com/
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
ADZUNA_COUNTRY=us

# ── APP ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
EMAIL_LIMIT_PER_DAY=200
